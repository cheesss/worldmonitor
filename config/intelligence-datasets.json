{
  "version": 1,
  "defaults": {
    "dbPath": "data/historical/intelligence-history.duckdb",
    "artifactDir": "data/historical/automation",
    "bucketHours": 6,
    "warmupFrameCount": 60,
    "replayWindowDays": 60,
    "walkForwardWindowDays": 180,
    "horizonsHours": [1, 4, 24, 72, 168],
    "fetchEveryMinutes": 60,
    "replayEveryMinutes": 60,
    "walkForwardLocalHour": 2,
    "themeDiscoveryEveryMinutes": 180,
    "keywordLifecycleEveryMinutes": 360,
    "maxRetries": 3,
    "retentionDays": 30,
    "artifactRetentionCount": 24,
    "lockTtlMinutes": 180
  },
  "themeAutomation": {
    "mode": "guarded-auto",
    "minDiscoveryScore": 58,
    "minSampleCount": 4,
    "minSourceCount": 2,
    "minCodexConfidence": 78,
    "minAssetCount": 2,
    "minPromotionScore": 72,
    "maxOverlapWithKnownThemes": 0.62,
    "maxPromotionsPerDay": 1
  },
  "sourceAutomation": {
    "mode": "guarded-auto",
    "minDiscoveredApproveConfidence": 84,
    "minDiscoveredActivateConfidence": 92,
    "minApiApproveConfidence": 90,
    "minApiActivateConfidence": 94,
    "maxDiscoveredActivationsPerCycle": 6,
    "maxApiActivationsPerCycle": 4,
    "maxDiscoveredActivationsPerCategory": 2,
    "maxDiscoveredActivationsPerDomain": 1,
    "maxApiActivationsPerCategory": 2,
    "maxApiActivationsPerBaseUrl": 1,
    "requireFeedLikeUrl": true,
    "requireHealthyApi": true,
    "minDiscoveredTopicCount": 2,
    "cooldownHours": 36,
    "healthRefreshBatch": 12,
    "staleHealthHours": 12
  },
  "candidateAutomation": {
    "enabled": true,
    "everyMinutes": 180,
    "maxThemesPerCycle": 2,
    "minGapSeverity": "elevated",
    "minCoverageScore": 60,
    "themeCooldownHours": 12,
    "maxThemesPerRegionPerCycle": 1
  },
  "datasetAutomation": {
    "enabled": true,
    "mode": "guarded-auto",
    "everyMinutes": 360,
    "codexTopThemesPerCycle": 2,
    "minProposalScore": 60,
    "autoRegisterScore": 74,
    "autoEnableScore": 88,
    "maxRegistrationsPerCycle": 2,
    "maxEnabledDatasets": 12,
    "allowProviders": ["fred", "alfred", "gdelt-doc", "coingecko", "acled"]
  },
  "experimentAutomation": {
    "enabled": true,
    "everyMinutes": 180
  },
  "datasets": [
    {
      "id": "coingecko-btc-core",
      "label": "CoinGecko BTC Core",
      "enabled": true,
      "provider": "coingecko",
      "fetchArgs": {
        "id": "bitcoin",
        "vs": "usd",
        "days": 365
      },
      "importOptions": {
        "bucketHours": 6,
        "warmupFrameCount": 60
      },
      "schedule": {
        "fetchEveryMinutes": 60,
        "replayEveryMinutes": 60
      }
    },
    {
      "id": "fred-core-cpi",
      "label": "FRED CPI Core",
      "enabled": true,
      "provider": "fred",
      "fetchArgs": {
        "series": "CPIAUCSL",
        "observation_start": "2018-01-01",
        "limit": 5000
      },
      "schedule": {
        "fetchEveryMinutes": 360,
        "replayEveryMinutes": 360
      }
    },
    {
      "id": "gdelt-middle-east",
      "label": "GDELT Middle East Chokepoints",
      "enabled": true,
      "provider": "gdelt-doc",
      "fetchArgs": {
        "query": "Hormuz OR tanker OR Red Sea OR missile OR drone OR oil",
        "mode": "ArtList",
        "max": 250
      },
      "schedule": {
        "fetchEveryMinutes": 60,
        "replayEveryMinutes": 60,
        "themeDiscoveryEveryMinutes": 120
      }
    },
    {
      "id": "acled-middle-east",
      "label": "ACLED Middle East",
      "enabled": true,
      "provider": "acled",
      "fetchArgs": {
        "country": "Iran",
        "event_types": "Battles|Explosions/Remote violence|Violence against civilians",
        "limit": 500
      },
      "schedule": {
        "fetchEveryMinutes": 180,
        "replayEveryMinutes": 180
      }
    }
  ]
}
